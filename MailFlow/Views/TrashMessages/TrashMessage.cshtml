@using System.Linq
@model List<MailFlow.Entities.Message>
@{
    ViewData["Title"] = "TrashMessage";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="max-w-5xl mx-auto mt-8">

    <div class="flex items-center justify-between mb-6">
        <h2 class="text-3xl font-bold text-slate-800 dark:text-slate-100">🗑 Çöp Kutusu</h2>
        <span class="text-sm text-slate-500">@Model.Count mesaj</span>
    </div>

    @if (!Model.Any())
    {
        <div class="bg-white dark:bg-slate-900 rounded-xl shadow-sm p-6 text-center text-slate-500">
            Çöp kutusunda henüz mesaj bulunmuyor.
        </div>
    }
    else
    {
        <div class="bg-white dark:bg-slate-900 rounded-xl shadow-sm border border-slate-200 dark:border-slate-700 overflow-hidden">
            @foreach (var msg in Model)
            {
                <div onclick="window.location='@Url.Action("MessageDetail", "Inbox", new { id = msg.MessageId })'"
                     class="flex items-center justify-between px-6 py-4 border-b hover:bg-red-50 dark:hover:bg-red-900/20 cursor-pointer transition group">

                    <!-- Sol Kısım -->
                    <div>
                        <p class="font-semibold text-slate-800 dark:text-slate-100 group-hover:text-red-600 transition">
                            @msg.Subject
                        </p>
                        <p class="text-sm text-slate-500 dark:text-slate-400">
                            Gönderen: @msg.SenderEmail
                        </p>
                        <p class="text-xs text-slate-400 dark:text-slate-500 mt-1">
                            @msg.SendDate.ToString("dd.MM.yyyy HH:mm")
                        </p>
                    </div>

                    <!-- Sağ Kısım -->
                    <div class="flex gap-2">
                        <!-- Geri Al -->
                        <a asp-action="RestoreMessage" asp-route-id="@msg.MessageId"
                           onclick="event.stopPropagation();"
                           class="px-3 py-2 rounded-lg bg-green-500 text-white text-sm font-semibold hover:bg-green-600 transition">
                            Geri Al
                        </a>

                        <!-- Kalıcı Sil -->
                        <a asp-action="DeletePermanently" asp-route-id="@msg.MessageId"
                           onclick="event.stopPropagation(); return confirm('Bu mesajı kalıcı olarak silmek istediğinize emin misiniz?');"
                           class="px-3 py-2 rounded-lg bg-red-500 text-white text-sm font-semibold hover:bg-red-600 transition">
                            Sil
                        </a>
                    </div>

                </div>
            }
        </div>
    }
</div>

