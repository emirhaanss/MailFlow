@model MailFlow.Dtos.UserLoginDto
@{
    Layout = null;
}

<html lang="tr">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no" />
    <title>MailFlow | Giriş</title>

    <link rel="stylesheet" href="~/template/assets/css/bootstrap.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://unpkg.com/boxicons@2.1.4/css/boxicons.min.css" />

    <style>
        body {
            font-family: 'Inter', sans-serif;
            background-color: #dfdbe5;
            background-image: radial-gradient(at 0% 0%, hsla(253,16%,7%,1) 0, transparent 50%), radial-gradient(at 50% 0%, hsla(225,39%,30%,1) 0, transparent 50%), radial-gradient(at 100% 0%, hsla(339,49%,30%,1) 0, transparent 50%);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .brand-logo {
            margin-bottom: 25px;
            display: flex;
            flex-direction: column;
            align-items: center;
        }

        .logo-circle {
            width: 60px;
            height: 60px;
            background: white;
            border-radius: 15px;
            display: flex;
            align-items: center;
            justify-content: center;
            box-shadow: 0 10px 20px rgba(0,0,0,0.2);
            font-size: 32px;
            color: #4f46e5;
        }

        .auth-card {
            background: rgba(255,255,255,0.98);
            border-radius: 20px;
            box-shadow: 0 25px 50px -12px rgba(0,0,0,0.5);
            width: 100%;
            max-width: 420px;
            padding: 30px;
        }


        .form-label {
            font-size: .8rem;
            font-weight: 600;
            text-transform: uppercase;
            color: #666;
        }

        .form-control {
            border-radius: 8px;
            background: #f8fafc;
        }

        .btn-login {
            background: #4f46e5;
            color: white;
            border-radius: 8px;
            padding: 11px;
            font-weight: 600;
        }

        .divider {
            height: 1px;
            background: #eee;
            margin: 20px 0;
        }
    </style>
</head>

<body>
    <div class="login-wrapper">

        <div class="brand-logo">
            <div class="logo-circle">
                <i class='bx bxs-envelope'></i>
            </div>
            <h5 class="text-white mt-2 fw-bold">MAILFLOW</h5>
        </div>

        <div class="auth-card">

            <div class="text-center mb-4">
                <h5 class="fw-bold">Hoş Geldiniz</h5>
                <small class="text-muted">Hesabınıza giriş yapın</small>
            </div>

            <form asp-controller="Login" asp-action="UserLogin" method="post">

                <div asp-validation-summary="ModelOnly" class="text-danger small mb-2"></div>

                <div class="mb-3">
                    <label class="form-label">Kullanıcı Adı</label>
                    <input asp-for="Username" class="form-control" placeholder="Kullanıcı Adı" />
                </div>

                <div class="mb-3">
                    <label class="form-label">Şifre</label>
                    <input asp-for="Password" type="password" class="form-control" placeholder="Şifre" />
                </div>

                <button type="submit" class="btn btn-login w-100">
                    GİRİŞ YAP
                </button>

            </form>

            <div class="divider"></div>

            <div class="text-center">
                <small>Hesabın yok mu?</small>
                <a href="/Register/CreateUser" class="fw-bold text-decoration-none">Kayıt Ol</a>
            </div>

        </div>

    </div>
</body>

</html>
