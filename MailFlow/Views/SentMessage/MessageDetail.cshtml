
@{
    ViewData["Title"] = "MessageDetail";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="max-w-3xl mx-auto mt-12">

    <!-- Modern Kart -->
    <div class="bg-white dark:bg-slate-900 shadow-xl rounded-2xl border border-slate-200 dark:border-slate-700 overflow-hidden">

        <!-- Üst Bilgi -->
        <div class="px-8 py-6 flex flex-col sm:flex-row sm:justify-between sm:items-center border-b border-slate-200 dark:border-slate-700">

            <div class="mb-4 sm:mb-0">
                <h1 class="text-3xl font-extrabold text-slate-900 dark:text-slate-100">@Model.Subject</h1>
                <p class="mt-1 text-sm text-slate-500 dark:text-slate-400">
                    Gönderen: <span class="font-semibold">@Model.SenderEmail</span>
                </p>
            </div>

            <div class="text-sm text-slate-400 dark:text-slate-500">
                @Model.SendDate.ToString("dd.MM.yyyy HH:mm")
            </div>
        </div>

        <!-- Mesaj İçeriği -->
        <div class="px-8 py-6 prose dark:prose-invert max-w-full">
            <p>@Model.MessageDetail</p>
        </div>

        <!-- Alt Butonlar -->
        <div class="px-8 py-4 border-t border-slate-200 dark:border-slate-700 flex justify-between items-center">
            <!-- İşlem Butonları -->
            <div class="flex gap-3">
                <a asp-action="SentMessages"
                   class="px-4 py-2 rounded-lg bg-gray-200 dark:bg-slate-800 text-gray-800 dark:text-slate-200 font-semibold hover:bg-gray-300 dark:hover:bg-slate-700 transition">
                    Geri
                </a>
                <a asp-action="DeleteMessage" asp-route-id="@Model.MessageId"
                   onclick="return confirm('Bu mesajı silmek istediğinize emin misiniz?');"
                   class="px-4 py-2 rounded-lg bg-red-500 text-white font-semibold hover:bg-red-600 transition">
                    Sil
                </a>
            </div>
        </div>

    </div>

</div>
